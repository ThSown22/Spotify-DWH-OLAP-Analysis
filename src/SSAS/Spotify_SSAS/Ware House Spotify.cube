  <MdxScripts>
    <MdxScript dwd:design-time-name="6a430c69-ea3b-44e3-b876-714f2183dbac">
      <ID>MdxScript</ID>
      <Name>MdxScript</Name>
      <CreatedTimestamp>0001-01-01T00:00:00Z</CreatedTimestamp>
      <LastSchemaUpdate>0001-01-01T00:00:00Z</LastSchemaUpdate>
      <Commands>
        <Command>
          <Text>/*
The CALCULATE command controls the aggregation of leaf cells in the cube.
If the CALCULATE command is deleted or modified, the data within the cube is affected.
You should edit this command only if you manually specify how the cube is aggregated.
*/
CALCULATE;                         
CREATE MEMBER CURRENTCUBE.[Measures].[Avg Popularity]
 AS AVG(
    [Dim Date].[Snapshot Date].[Snapshot Date].MEMBERS,
    [Measures].[Peak Popularity]
), 
FORMAT_STRING = "0", 
VISIBLE = 1 ,  DISPLAY_FOLDER = 'Market Trends' ,  ASSOCIATED_MEASURE_GROUP = 'Fact Daily';                                 
CREATE MEMBER CURRENTCUBE.[Measures].[Avg Danceability]
 AS AVG(
    NONEMPTY(
        [Dim Track].[Spotify Id].[Spotify Id].MEMBERS, 
        [Measures].[Days On Chart]
    ),
    [Dim Track].[Danceability].MemberValue
), 
FORMAT_STRING = "0", 
VISIBLE = 1 ,  DISPLAY_FOLDER = 'Market Trends' ,  ASSOCIATED_MEASURE_GROUP = 'Fact Daily';                                 
CREATE MEMBER CURRENTCUBE.[Measures].[Days in Top 10]
 AS COUNT(
    FILTER(
        [Dim Date].[Snapshot Date].[Snapshot Date].MEMBERS,
        [Measures].[Best Rank] &gt; 0 AND [Measures].[Best Rank] &lt;= 10
    )
), 
FORMAT_STRING = "0", 
VISIBLE = 1 ,  DISPLAY_FOLDER = 'Performance' ,  ASSOCIATED_MEASURE_GROUP = 'Fact Daily';                                 
CREATE MEMBER CURRENTCUBE.[Measures].[Viral Hit Count]
 AS SUM(
    [Dim Date].[Snapshot Date].[Snapshot Date].MEMBERS,
    IIF([Measures].[Daily Move Max] &gt;= 20, 1, NULL)
), 
FORMAT_STRING = "0", 
VISIBLE = 1 ,  DISPLAY_FOLDER = 'Market Trends' ,  ASSOCIATED_MEASURE_GROUP = 'Fact Daily'; </Text>
        </Command>
      </Commands>
    </MdxScript>
  </MdxScripts>
</Cube>